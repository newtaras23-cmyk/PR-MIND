# Lead routing (server-side, TZ §6A.2) — leave unset to keep the no-op scaffold.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LEAD_WEBHOOK_URL=

# Contact channels (client-side, TZ §6A.1) — fill before M6.
NEXT_PUBLIC_TELEGRAM_HANDLE=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_SIGNAL_HANDLE=
NEXT_PUBLIC_VIBER_NUMBER=
NEXT_PUBLIC_MESSENGER_USERNAME=

# Booking (TZ §6A.1)
NEXT_PUBLIC_CAL_COM_LINK=

# Analytics (TZ §6A.3) — optional, disabled by default.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Canonical site origin used in metadata/JSON-LD/sitemap. Defaults to the
# placeholder production domain; set for staging so canonicals match the real host.
NEXT_PUBLIC_SITE_URL=
